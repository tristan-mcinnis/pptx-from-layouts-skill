      "use_case": "Contact information (dark)"
    },
    "contact_white": {
      "layout_index": 51,
      "layout_name": "contact-white",
      "use_case": "Contact information (light)"
    },
    "grid_3x2_3body": {
      "layout_index": 36,
      "layout_name": "grid-3x2-image-top-3-body",
